{
  "expo": {
    "name": "DailyDo",
    "slug": "dailydo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dailydo",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E7D32"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.antonio.dailydo"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#2E7D32"
      },
      "package": "com.antonio.dailydo"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#2E7D32"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "41051cd5-f2ed-4c0f-b4ae-ccf437510df3"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/41051cd5-f2ed-4c0f-b4ae-ccf437510df3"
    }
  }
}
